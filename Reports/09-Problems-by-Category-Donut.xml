<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Problems by Category (Donut Chart)
    Type: Donut Chart
    Table: problem
    Group By: Category
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_problem_cat_donut</sys_id>
    <name>Problems by Category</name>
    <title>Problems by Category</title>
    <table>problem</table>
    <type>donut</type>
    <active>true</active>
    <group_by>category</group_by>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>2</order_by>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Donut chart showing problem distribution by category. Helps identify which areas generate the most problem records, indicating potential systemic issues.</description>
    <filter_condition>active=true</filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <chart_type>donut</chart_type>
    <show_data_labels>true</show_data_labels>
    <show_legend>true</show_legend>
    <legend_position>right</legend_position>
    <hole_size>50</hole_size>
    <center_label>Problems</center_label>
  </sys_reports>
</unload>
