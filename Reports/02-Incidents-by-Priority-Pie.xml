<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Incidents by Priority (Pie Chart)
    Type: Pie Chart
    Table: Incident
    Group By: Priority
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_inc_pri_pie</sys_id>
    <name>Incidents by Priority</name>
    <title>Incidents by Priority</title>
    <table>incident</table>
    <type>pie</type>
    <active>true</active>
    <group_by>priority</group_by>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>ASC</order_direction>
    <order_by>1</order_by>
    <limit_count>0</limit_count>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Pie chart showing the distribution of incidents across priority levels (1-Critical to 5-Planning). Critical and High priority incidents are highlighted for immediate attention.</description>
    <filter_condition>active=true</filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <time_series>false</time_series>
    <chart_type>pie</chart_type>
    <show_data_labels>true</show_data_labels>
    <show_legend>true</show_legend>
    <legend_position>right</legend_position>
    <!-- Color mapping for priorities -->
    <color_map>
      <color priority="1" value="#dc3545"/> <!-- Critical - Red -->
      <color priority="2" value="#fd7e14"/> <!-- High - Orange -->
      <color priority="3" value="#ffc107"/> <!-- Medium - Yellow -->
      <color priority="4" value="#28a745"/> <!-- Low - Green -->
      <color priority="5" value="#17a2b8"/> <!-- Planning - Blue -->
    </color_map>
  </sys_reports>
</unload>
