<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Changes by Type (Pie Chart)
    Type: Pie Chart
    Table: change_request
    Group By: Type
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_change_type_pie</sys_id>
    <name>Changes by Type</name>
    <title>Changes by Type</title>
    <table>change_request</table>
    <type>pie</type>
    <active>true</active>
    <group_by>type</group_by>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>2</order_by>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Pie chart showing the distribution of change requests by type (Infrastructure, Application, Security, etc.). Helps understand the change portfolio balance.</description>
    <filter_condition>active=true</filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <chart_type>pie</chart_type>
    <show_data_labels>true</show_data_labels>
    <show_legend>true</show_legend>
    <legend_position>right</legend_position>
  </sys_reports>
</unload>
