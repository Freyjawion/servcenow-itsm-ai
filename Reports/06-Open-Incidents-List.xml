<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Open Incidents (List Report)
    Type: List
    Table: Incident
    Columns: Number, Short Description, Category, Priority, State, Assignment Group, Assigned To, Created On, SLA Status
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_inc_open_list</sys_id>
    <name>Open Incidents</name>
    <title>Open Incidents</title>
    <table>incident</table>
    <type>list</type>
    <active>true</active>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>1</order_by>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>
      List report showing all currently open incidents with key details.
      Useful for daily stand-ups and operational reviews.
      Columns: Incident Number, Short Description, Category, Priority, State, Assignment Group, Assigned To, Created On
    </description>
    <filter_condition>
      stateIN1,2,3^ORDERBYDESCsys_created_on
    </filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <display_rows>50</display_rows>
    <list_columns>number,short_description,category,priority,state,assignment_group,assigned_to,sys_created_on</list_columns>
    <enable_export>true</enable_export>
    <export_formats>pdf,excel,csv</export_formats>
  </sys_reports>
</unload>
