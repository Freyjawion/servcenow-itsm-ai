<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Dashboard: ITSM Operations Dashboard
    Displays all 12 reports in a 3-column × 4-row layout
    Every report has time range selector enabled
  -->
  <sys_dashboard action="INSERT_OR_UPDATE">
    <sys_id>itsm_dashboard_ops</sys_id>
    <name>ITSM Operations Dashboard</name>
    <title>ITSM Operations Dashboard</title>
    <active>true</active>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>
      Comprehensive ITSM Operations Dashboard showing key metrics across Incident, Problem, Change, and SLA domains.
      - Incident: Category, Priority, Trend, Group distribution
      - Problem: Category distribution, State pipeline
      - Change: Type distribution, Trend
      - SLA: Breach analysis
      - All reports support time range filtering
    </description>
    <roles/>
    <show_title>true</show_title>
    <view_name>itsm_ops_dashboard</view_name>
    <width_units>px</width_units>
    <dashboard_width>1200</dashboard_width>

    <!-- Dashboard Tabs -->
    <tabs>
      <!-- Tab 1: Incident Overview -->
      <tab>
        <sys_id>tab_incident_overview</sys_id>
        <label>Incident Overview</label>
        <order>100</order>
        <panels>
          <!-- Row 1: Category Bar + Priority Pie + Resolution Time Score -->
          <panel>
            <sys_id>panel_inc_row1</sys_id>
            <order>100</order>
            <columns>3</columns>
            <rows>
              <row>
                <sys_id>rpt_inc_cat_bar_slot</sys_id>
                <report>itsm_rpt_inc_cat_bar</report>
                <title>Incidents by Category</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>100</order>
              </row>
              <row>
                <sys_id>rpt_inc_pri_pie_slot</sys_id>
                <report>itsm_rpt_inc_pri_pie</report>
                <title>Incidents by Priority</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>200</order>
              </row>
              <row>
                <sys_id>rpt_inc_reso_score_slot</sys_id>
                <report>itsm_rpt_inc_reso_score</report>
                <title>Avg Resolution Time</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>300</order>
              </row>
            </rows>
          </panel>
          <!-- Row 2: Trend Line + Group Column + Pivot Table -->
          <panel>
            <sys_id>panel_inc_row2</sys_id>
            <order>200</order>
            <columns>3</columns>
            <rows>
              <row>
                <sys_id>rpt_inc_time_line_slot</sys_id>
                <report>itsm_rpt_inc_time_line</report>
                <title>Incidents Over Time</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>100</order>
              </row>
              <row>
                <sys_id>rpt_inc_grp_col_slot</sys_id>
                <report>itsm_rpt_inc_grp_col</report>
                <title>Incidents by Group</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>200</order>
              </row>
              <row>
                <sys_id>rpt_inc_cat_pri_pivot_slot</sys_id>
                <report>itsm_rpt_inc_cat_pri_pivot</report>
                <title>Category × Priority</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>300</order>
              </row>
            </rows>
          </panel>
          <!-- Row 3: Open Incidents List (full width) -->
          <panel>
            <sys_id>panel_inc_row3</sys_id>
            <order>300</order>
            <columns>1</columns>
            <rows>
              <row>
                <sys_id>rpt_inc_open_list_slot</sys_id>
                <report>itsm_rpt_inc_open_list</report>
                <title>Open Incidents</title>
                <width>1</width>
                <height>2</height>
                <show_filter>true</show_filter>
                <show_time_range>true</show_time_range>
                <order>100</order>
              </row>
            </rows>
          </panel>
        </panels>
      </tab>

      <!-- Tab 2: Problem & Change Overview -->
      <tab>
        <sys_id>tab_problem_change</sys_id>
        <label>Problem &amp; Change</label>
        <order>200</order>
        <panels>
          <!-- Row 1: Problem Donut + Problem State + Change Pie -->
          <panel>
            <sys_id>panel_pc_row1</sys_id>
            <order>100</order>
            <columns>3</columns>
            <rows>
              <row>
                <sys_id>rpt_problem_cat_donut_slot</sys_id>
                <report>itsm_rpt_problem_cat_donut</report>
                <title>Problems by Category</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>100</order>
              </row>
              <row>
                <sys_id>rpt_problem_state_bar_slot</sys_id>
                <report>itsm_rpt_problem_state_bar</report>
                <title>Problems by State</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>200</order>
              </row>
              <row>
                <sys_id>rpt_change_type_pie_slot</sys_id>
                <report>itsm_rpt_change_type_pie</report>
                <title>Changes by Type</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>300</order>
              </row>
            </rows>
          </panel>
          <!-- Row 2: Change Trend + SLA Breaches (full width) -->
          <panel>
            <sys_id>panel_pc_row2</sys_id>
            <order>200</order>
            <columns>2</columns>
            <rows>
              <row>
                <sys_id>rpt_change_time_line_slot</sys_id>
                <report>itsm_rpt_change_time_line</report>
                <title>Changes Over Time</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>100</order>
              </row>
              <row>
                <sys_id>rpt_sla_breach_bar_slot</sys_id>
                <report>itsm_rpt_sla_breach_bar</report>
                <title>SLA Breaches</title>
                <width>1</width>
                <height>1</height>
                <show_filter>false</show_filter>
                <show_time_range>true</show_time_range>
                <order>200</order>
              </row>
            </rows>
          </panel>
        </panels>
      </tab>
    </tabs>
  </sys_dashboard>
</unload>
