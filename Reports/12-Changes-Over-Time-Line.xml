<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Changes Over Time (Time Series Line)
    Type: Time Series Line Chart
    Table: change_request
    Group By: Created On (by week)
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_change_time_line</sys_id>
    <name>Changes Over Time</name>
    <title>Changes Over Time</title>
    <table>change_request</table>
    <type>line</type>
    <active>true</active>
    <time_series>true</time_series>
    <time_series_field>sys_created_on</time_series_field>
    <time_series_interval>weekly</time_series_interval>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>2</order_by>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Line chart showing change request creation trends over time. Helps identify change windows, freeze periods, and overall change management activity.</description>
    <filter_condition>active=true</filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <time_range>last_90_days</time_range>
    <chart_type>line</chart_type>
    <show_data_labels>false</show_data_labels>
    <show_legend>false</show_legend>
    <show_grid>true</show_grid>
    <line_color>#28a745</line_color>
    <line_width>2</line_width>
    <chart_area_background_color>#f8f9fa</chart_area_background_color>
  </sys_reports>
</unload>
