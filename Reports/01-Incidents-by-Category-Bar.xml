<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Incidents by Category (Bar Chart)
    Type: Bar Chart
    Table: Incident
    Group By: Category
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_inc_cat_bar</sys_id>
    <name>Incidents by Category</name>
    <title>Incidents by Category</title>
    <table>incident</table>
    <type>bar</type>
    <active>true</active>
    <group_by>category</group_by>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>2</order_by>
    <limit_count>0</limit_count>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Bar chart showing the number of incidents grouped by category. Helps visualize workload distribution across Hardware, Software, Network, and Others categories.</description>
    <filter_condition>active=true^ORDERBYDESCnumber</filter_condition>
    <roles/>
    <!-- Time range picker enabled -->
    <time_range_select>true</time_range_select>
    <time_series>false</time_series>
    <!-- Display as horizontal bars -->
    <chart_type>bar</chart_type>
    <stacked>false</stacked>
    <show_data_labels>true</show_data_labels>
    <show_legend>true</show_legend>
    <legend_position>bottom</legend_position>
  </sys_reports>
</unload>
