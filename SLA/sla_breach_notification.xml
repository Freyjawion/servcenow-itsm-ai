<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Notification: SLA Breach
    Event: sla.breached
    When: SLA duration has expired (100% elapsed)
    Recipients: Assigned group + Assignee + Manager + VIP
  -->
  <sysevent_email_action action="INSERT_OR_UPDATE">
    <sys_id>itsm_notif_sla_breach</sys_id>
    <name>SLA Breach</name>
    <active>true</active>
    <table>incident</table>
    <event_name>sla.breached</event_name>
    <description>Sent when an SLA has been breached. Duration has fully elapsed without resolution.</description>
    <recipients>
      <recipient type="group" field="assignment_group"/>
      <recipient type="user" field="assigned_to"/>
      <recipient type="user" field="caller_id"/>
    </recipients>
    <subject>[SLA BREACHED] ${number} - ${short_description}</subject>
    <message_html>
<html>
<body style="font-family: Arial, sans-serif; padding: 20px;">
  <div style="border: 2px solid #dc3545; border-radius: 8px; padding: 0;">
    <div style="background: #dc3545; padding: 15px; border-bottom: 2px solid #c82333; text-align: center;">
      <h2 style="margin: 0; color: white;">🚨 SLA BREACHED</h2>
    </div>
    <div style="padding: 20px;">
      <div style="background: #f8d7da; border: 1px solid #f5c6cb; border-radius: 6px; padding: 15px; margin: 0 0 15px 0; text-align: center;">
        <p style="margin: 0; color: #721c24; font-size: 18px; font-weight: bold;">
          The SLA for this incident has been breached.
        </p>
      </div>

      <div style="background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 6px; padding: 15px; margin: 15px 0;">
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057; width: 160px;">Incident #</td>
            <td style="padding: 6px;"><a href="${URI_REF}"><strong>${number}</strong></a></td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Short Description</td>
            <td style="padding: 6px;">${short_description}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Priority</td>
            <td style="padding: 6px;"><span style="background: #dc3545; color: white; padding: 2px 8px; border-radius: 4px;">${priority}</span></td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assignment Group</td>
            <td style="padding: 6px;">${assignment_group}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assigned To</td>
            <td style="padding: 6px;">${assigned_to}</td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">State</td>
            <td style="padding: 6px;">${state}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Caller</td>
            <td style="padding: 6px;">${caller_id}</td>
          </tr>
        </table>
      </div>

      <div style="background: #dc3545; color: white; border-radius: 6px; padding: 15px; margin: 15px 0;">
        <h3 style="margin: 0 0 10px 0;">📋 Required Actions:</h3>
        <ol style="margin: 0; padding-left: 20px; line-height: 1.8;">
          <li><strong>Contact the caller immediately</strong> to acknowledge the delay</li>
          <li><strong>Provide an updated ETA</strong> for resolution</li>
          <li><strong>Elevate to management</strong> if additional resources are needed</li>
          <li><strong>Document the breach reason</strong> in work notes</li>
          <li><strong>Create a post-incident review</strong> task if required</li>
        </ol>
      </div>

      <p style="padding: 10px 0; text-align: center;">
        <a href="${URI_REF}" style="display: inline-block; padding: 12px 30px; background: #dc3545; color: white; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px;">
          🔗 VIEW AND UPDATE INCIDENT
        </a>
      </p>
    </div>
  </div>

  <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">
  <p style="color: #999; font-size: 12px;">
    This is an automated SLA notification from ServiceNow ITSM Demo.
  </p>
</body>
</html>
    </message_html>
    <weight>100</weight>
  </sysevent_email_action>
</unload>
