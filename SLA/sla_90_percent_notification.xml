<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Notification: SLA 90% Urgent Warning
    Event: sla.90_percent
    When: 90% of SLA duration has elapsed
    Recipients: Assigned group + Assignee + Manager
  -->
  <sysevent_email_action action="INSERT_OR_UPDATE">
    <sys_id>itsm_notif_sla_90_pct</sys_id>
    <name>SLA - 90% Urgent Warning</name>
    <active>true</active>
    <table>incident</table>
    <event_name>sla.90_percent</event_name>
    <description>Sent when 90% of SLA duration has elapsed. Second and urgent warning notification.</description>
    <recipients>
      <recipient type="group" field="assignment_group"/>
      <recipient type="user" field="assigned_to"/>
    </recipients>
    <subject>[SLA URGENT - 90%] ${number} - ${short_description}</subject>
    <message_html>
<html>
<body style="font-family: Arial, sans-serif; padding: 20px;">
  <div style="border: 2px solid #fd7e14; border-radius: 8px; padding: 0;">
    <div style="background: #ffe0b2; padding: 15px; border-bottom: 1px solid #fd7e14;">
      <h2 style="margin: 0; color: #d84315;">🔴 URGENT - 90% SLA Elapsed</h2>
    </div>
    <div style="padding: 20px;">
      <p><strong>This incident has reached 90% of its SLA duration.</strong></p>
      <p style="color: #d84315;"><strong>⚠️ CRITICAL: SLA breach is imminent if no action is taken immediately!</strong></p>

      <div style="background: #fff8e1; border: 2px solid #fd7e14; border-radius: 6px; padding: 15px; margin: 15px 0;">
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057; width: 160px;">Incident #</td>
            <td style="padding: 6px;"><a href="${URI_REF}"><strong>${number}</strong></a></td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Short Description</td>
            <td style="padding: 6px;"><strong>${short_description}</strong></td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Priority</td>
            <td style="padding: 6px;"><span style="background: #dc3545; color: white; padding: 2px 8px; border-radius: 4px;">${priority}</span></td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assignment Group</td>
            <td style="padding: 6px;">${assignment_group}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assigned To</td>
            <td style="padding: 6px;">${assigned_to}</td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">State</td>
            <td style="padding: 6px;">${state}</td>
          </tr>
        </table>
      </div>

      <div style="background: #dc3545; color: white; border-radius: 6px; padding: 12px; margin: 15px 0; text-align: center;">
        <p style="margin: 0; font-size: 16px; font-weight: bold;">
          ⏰ SLA BREACH WILL OCCUR IN MINUTES IF NOT RESOLVED
        </p>
      </div>

      <p style="padding: 10px 0; text-align: center;">
        <a href="${URI_REF}" style="display: inline-block; padding: 12px 30px; background: #dc3545; color: white; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px;">
          🔗 RESOLVE INCIDENT NOW
        </a>
      </p>
    </div>
  </div>

  <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">
  <p style="color: #999; font-size: 12px;">
    This is an automated SLA notification from ServiceNow ITSM Demo.
  </p>
</body>
</html>
    </message_html>
    <weight>100</weight>
  </sysevent_email_action>
</unload>
