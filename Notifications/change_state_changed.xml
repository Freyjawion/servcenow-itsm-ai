<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Notification: Change State Changed
    When: Event 'change.state_changed' is triggered
    Who: Assigned group members, change manager
    How: Email
  -->
  <sysevent_email_action action="INSERT_OR_UPDATE">
    <sys_id>itsm_notif_change_state_changed</sys_id>
    <name>Change State Changed</name>
    <active>true</active>
    <table>change_request</table>
    <event_name>change.state_changed</event_name>
    <description>Sent when the state of a change request changes</description>
    <recipients>
      <recipient type="group">assignment_group</recipient>
      <recipient type="caller">assigned_to</recipient>
    </recipients>
    <subject>Change ${number} State Updated: ${state} - ${short_description}</subject>
    <message_html>
<html>
<body style="font-family: Arial, sans-serif; padding: 20px;">
  <h2 style="color: #e67e22;">🔄 Change State Updated</h2>
  
  <div style="background: #d4edda; border: 1px solid #28a745; border-radius: 8px; padding: 15px; margin: 15px 0;">
    <strong style="color: #155724;">✅ State Change:</strong>
    <span style="color: #155724;">The change state has been updated to <strong>${state}</strong></span>
  </div>
  
  <div style="background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; margin: 15px 0;">
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057; width: 130px;">Change #</td>
        <td style="padding: 8px;"><a href="${URI_REF}">${number}</a></td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Current State</td>
        <td style="padding: 8px; font-size: 15px;"><strong>${state}</strong></td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Type</td>
        <td style="padding: 8px;">${type}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Short Description</td>
        <td style="padding: 8px;">${short_description}</td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Priority</td>
        <td style="padding: 8px;">${priority}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Assignment Group</td>
        <td style="padding: 8px;">${assignment_group}</td>
      </tr>
    </table>
  </div>
  
  <div style="margin-top: 25px; padding: 15px; background: #fff3cd; border-radius: 6px;">
    <p style="margin: 0; color: #856404;">
      📍 <a href="${URI_REF}" style="color: #e67e22;">Click here to view the latest updates</a>
    </p>
  </div>
  
  <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">
  <p style="color: #999; font-size: 12px;">
    This is an automated notification from ServiceNow ITSM Demo - Change Management.
  </p>
</body>
</html>
    </message_html>
    <weight>200</weight>
  </sysevent_email_action>
</unload>
