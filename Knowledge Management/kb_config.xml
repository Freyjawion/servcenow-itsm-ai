<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- Knowledge Base 1: Technical Knowledge Base -->
  <kb_knowledge_base action="INSERT_OR_UPDATE">
    <sys_id>kb_technical_base</sys_id>
    <name>Technical Knowledge Base</name>
    <title>Technical Knowledge Base</title>
    <description>Technical knowledge base for internal support teams. Contains technical documentation, troubleshooting guides, and system configurations. Access restricted to technical support staff (L1, L2, L3). Articles require approval before publishing.</description>
    <retire_article_days>365</retire_article_days>
    <is_valid>true</is_valid>
    <order>100</order>
    <roles/>
  </kb_knowledge_base>

  <!-- Knowledge Base 2: Employee Knowledge Base -->
  <kb_knowledge_base action="INSERT_OR_UPDATE">
    <sys_id>kb_employee_base</sys_id>
    <name>Employee Knowledge Base</name>
    <title>Employee Knowledge Base</title>
    <description>Employee knowledge base available to all staff. Contains FAQs, how-to guides, company policies, and general information. Open to all employees. Articles are auto-published without approval.</description>
    <retire_article_days>365</retire_article_days>
    <is_valid>true</is_valid>
    <order>200</order>
    <roles/>
  </kb_knowledge_base>

  <!-- KB Category: Technical - Hardware -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_tech_hardware</sys_id>
    <label>Hardware Troubleshooting</label>
    <kb_knowledge_base>kb_technical_base</kb_knowledge_base>
    <parent/>
    <order>100</order>
  </kb_category>

  <!-- KB Category: Technical - Software -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_tech_software</sys_id>
    <label>Software Troubleshooting</label>
    <kb_knowledge_base>kb_technical_base</kb_knowledge_base>
    <parent/>
    <order>200</order>
  </kb_category>

  <!-- KB Category: Technical - Network -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_tech_network</sys_id>
    <label>Network Troubleshooting</label>
    <kb_knowledge_base>kb_technical_base</kb_knowledge_base>
    <parent/>
    <order>300</order>
  </kb_category>

  <!-- KB Category: Employee - General -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_emp_general</sys_id>
    <label>General Information</label>
    <kb_knowledge_base>kb_employee_base</kb_knowledge_base>
    <parent/>
    <order>100</order>
  </kb_category>

  <!-- KB Category: Employee - FAQ -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_emp_faq</sys_id>
    <label>Frequently Asked Questions</label>
    <kb_knowledge_base>kb_employee_base</kb_knowledge_base>
    <parent/>
    <order>200</order>
  </kb_category>

  <!-- KB Category: Employee - Policy -->
  <kb_category action="INSERT_OR_UPDATE">
    <sys_id>kb_emp_policy</sys_id>
    <label>Company Policies</label>
    <kb_knowledge_base>kb_employee_base</kb_knowledge_base>
    <parent/>
    <order>300</order>
  </kb_category>
</unload>
