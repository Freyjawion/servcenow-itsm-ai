  <!-- INBOUND EMAIL ACTION                                        -->
  <!-- ========================================================== -->
  <sys_inbound_email_action action="INSERT_OR_UPDATE">
    <sys_id>a82d0000000000000000000000d033</sys_id>
    <name>Create Incident from Email</name>
    <active>true</active>
    <table>incident</table>
    <type>new</type>
    <action_order>100</action_order>
    <script><![CDATA[
(function runAction(/*GlideRecord*/ current, /*GlideRecord*/ event, /*EmailWrapper*/ email, /*ScopedEmailLogger*/ logger) {
    try {
        var parser = new ITSMEmailParser();
        var parsed = parser.parseAndCreateIncident(email, current);
        
        if (parsed) {
            current.subject = 'Incident created from email: ' + email.subject;
            current.contact_type = 'email';
            
            gs.info('Inbound Email: Incident created from email - Subject: ' + email.subject);
        } else {
            gs.warn('Inbound Email: Failed to parse email for incident creation');
        }
    } catch (e) {
        gs.error('Inbound Email: Error in Create Incident from Email - ' + e.message);
    }
})(current, event, email, logger);
    ]]></script>
  </sys_inbound_email_action>

