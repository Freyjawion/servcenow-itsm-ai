        <td style="padding: 8px;">${state}</td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Caller</td>
        <td style="padding: 8px;">${caller_id}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Urgency</td>
        <td style="padding: 8px; font-size: 14px;"><strong>${urgency}</strong></td>
      </tr>
    </table>
  </div>
  
  <h3 style="color: #2c3e50;">Description</h3>
