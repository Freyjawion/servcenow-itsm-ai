      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057; width: 130px;">Incident #</td>
        <td style="padding: 8px;"><a href="${URI_REF}" style="color: #dc3545; font-weight: bold;">${number}</a></td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Short Description</td>
