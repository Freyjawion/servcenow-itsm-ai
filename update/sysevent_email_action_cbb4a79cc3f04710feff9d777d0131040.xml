    <span style="color: #721c24;">- This change requires CAB approval before implementation.</span>
  </div>
  
  <div style="background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; margin: 15px 0;">
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057; width: 130px;">Change #</td>
        <td style="padding: 8px;"><a href="${URI_REF}">${number}</a></td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Short Description</td>
        <td style="padding: 8px;">${short_description}</td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Type</td>
        <td style="padding: 8px;">${type}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Priority</td>
        <td style="padding: 8px; font-size: 15px;"><strong>${priority}</strong></td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Risk</td>
        <td style="padding: 8px;">${risk}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Assignment Group</td>
        <td style="padding: 8px;">${assignment_group}</td>
      </tr>
      <tr>
        <td style="padding: 8px; font-weight: bold; color: #495057;">Planned Start</td>
        <td style="padding: 8px;">${start_date}</td>
      </tr>
      <tr style="background: #fff;">
        <td style="padding: 8px; font-weight: bold; color: #495057;">Planned End</td>
        <td style="padding: 8px;">${end_date}</td>
      </tr>
    </table>
  </div>

  <p style="background: #fff; border: 1px solid #dee2e6; border-radius: 4px; padding: 12px; white-space: pre-line;">${description}</p>
  
  <div style="margin-top: 25px; padding: 15px; background: #f8d7da; border-radius: 6px;">
