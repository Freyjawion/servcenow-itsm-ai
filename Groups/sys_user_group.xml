<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Groups Configuration for ITSM Demo
    L1 Groups (multiple, assigned by category)
    L2 Group (single, for escalated incidents)
    L3 Groups (multiple, for change management)
  -->
  
  <!-- L1 Groups -->
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l1_hardware</sys_id>
    <name>Hardware Support</name>
    <description>L1 - Hardware Incident Support</description>
    <type>itsm_l1_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l1_software</sys_id>
    <name>Software Support</name>
    <description>L1 - Software Incident Support</description>
    <type>itsm_l1_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l1_network</sys_id>
    <name>Network Support</name>
    <description>L1 - Network Incident Support</description>
    <type>itsm_l1_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l1_others</sys_id>
    <name>Others Support</name>
    <description>L1 - Other Category Incident Support</description>
    <type>itsm_l1_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <!-- L2 Group -->
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l2_team</sys_id>
    <name>L2 Support Team</name>
    <description>L2 - Escalated Incident Support</description>
    <type>itsm_l2_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <!-- L3 Groups (Change Management) -->
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l3_infra</sys_id>
    <name>Change Management - Infrastructure</name>
    <description>L3 - Infrastructure Change Management</description>
    <type>itsm_l3_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l3_app</sys_id>
    <name>Change Management - Application</name>
    <description>L3 - Application Change Management</description>
    <type>itsm_l3_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
  
  <sys_user_group action="INSERT_OR_UPDATE">
    <sys_id>itsm_group_l3_security</sys_id>
    <name>Change Management - Security</name>
    <description>L3 - Security Change Management</description>
    <type>itsm_l3_group</type>
    <active>true</active>
    <manager></manager>
  </sys_user_group>
</unload>
