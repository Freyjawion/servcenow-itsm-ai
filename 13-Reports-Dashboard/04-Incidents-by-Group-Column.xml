<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Report: Incidents by Assignment Group (Column Chart)
    Type: Column Chart
    Table: Incident
    Group By: Assignment Group
    Time filter enabled: Yes
  -->
  <sys_reports action="INSERT_OR_UPDATE">
    <sys_id>itsm_rpt_inc_grp_col</sys_id>
    <name>Incidents by Assignment Group</name>
    <title>Incidents by Assignment Group</title>
    <table>incident</table>
    <type>column</type>
    <active>true</active>
    <group_by>assignment_group</group_by>
    <aggregate>COUNT</aggregate>
    <show_condition>true</show_condition>
    <order_direction>DESC</order_direction>
    <order_by>2</order_by>
    <limit_count>10</limit_count>
    <sys_created_by>admin</sys_created_by>
    <sys_updated_by>admin</sys_updated_by>
    <description>Column chart showing the top 10 assignment groups by incident count. Useful for monitoring workload distribution across L1, L2, and L3 support groups.</description>
    <filter_condition>assignment_group!=NULL</filter_condition>
    <roles/>
    <time_range_select>true</time_range_select>
    <time_series>false</time_series>
    <chart_type>column</chart_type>
    <stacked>false</stacked>
    <show_data_labels>true</show_data_labels>
    <show_legend>false</show_legend>
    <orientation>vertical</orientation>
  </sys_reports>
</unload>
