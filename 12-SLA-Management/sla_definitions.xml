<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- ============================================ -->
  <!-- Response SLA Definitions                     -->
  <!-- ============================================ -->

  <!-- Response SLA - Critical (Priority 1) - 15 minutes -->
  <contract_sla action="INSERT_OR_UPDATE">
    <sys_id>sla_resp_critical</sys_id>
    <name>Response SLA - Critical</name>
    <table>incident</table>
    <type>response</type>
    <business_rule>Priority is 1</business_rule>
    <business_duration>900</business_duration>  <!-- 15 minutes in seconds -->
    <duration_type>business</duration_type>
    <active>true</active>
    <order>100</order>
    <description>Response SLA for Critical priority incidents. First response within 15 minutes.</description>
    <condition>current.priority == 1</condition>
  </contract_sla>

