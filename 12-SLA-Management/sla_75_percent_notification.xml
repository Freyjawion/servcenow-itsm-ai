<?xml version="1.0" encoding="UTF-8"?>
<unload>
  <!-- 
    Notification: SLA 75% Warning
    Event: sla.75_percent
    When: 75% of SLA duration has elapsed
    Recipients: Assigned group + Assignee
  -->
  <sysevent_email_action action="INSERT_OR_UPDATE">
    <sys_id>itsm_notif_sla_75_pct</sys_id>
    <name>SLA - 75% Warning</name>
    <active>true</active>
    <table>incident</table>
    <event_name>sla.75_percent</event_name>
    <description>Sent when 75% of SLA duration has elapsed. First warning notification.</description>
    <recipients>
      <recipient type="group" field="assignment_group"/>
      <recipient type="user" field="assigned_to"/>
    </recipients>
    <subject>[SLA WARNING - 75%] ${number} - ${short_description}</subject>
    <message_html>
<html>
<body style="font-family: Arial, sans-serif; padding: 20px;">
  <div style="border: 2px solid #ffc107; border-radius: 8px; padding: 0;">
    <div style="background: #fff3cd; padding: 15px; border-bottom: 1px solid #ffc107;">
      <h2 style="margin: 0; color: #856404;">⚠️ SLA Warning - 75% Elapsed</h2>
    </div>
    <div style="padding: 20px;">
      <p><strong>This incident has reached 75% of its SLA duration.</strong></p>
      <p><strong>Immediate action is required to avoid SLA breach.</strong></p>

      <div style="background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 6px; padding: 15px; margin: 15px 0;">
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057; width: 160px;">Incident #</td>
            <td style="padding: 6px;"><a href="${URI_REF}">${number}</a></td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Short Description</td>
            <td style="padding: 6px;">${short_description}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Priority</td>
            <td style="padding: 6px;">${priority}</td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assignment Group</td>
            <td style="padding: 6px;">${assignment_group}</td>
          </tr>
          <tr>
            <td style="padding: 6px; font-weight: bold; color: #495057;">Assigned To</td>
            <td style="padding: 6px;">${assigned_to}</td>
          </tr>
          <tr style="background: #fff;">
            <td style="padding: 6px; font-weight: bold; color: #495057;">State</td>
            <td style="padding: 6px;">${state}</td>
          </tr>
        </table>
      </div>

      <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 12px; margin: 15px 0;">
        <p style="margin: 0; color: #856404;">
          🔔 <strong>Action Required:</strong> Please respond or progress this incident as soon as possible to avoid SLA breach.
        </p>
      </div>

      <p style="padding: 10px 0;">
        <a href="${URI_REF}" style="display: inline-block; padding: 10px 20px; background: #007bff; color: white; text-decoration: none; border-radius: 5px; font-weight: bold;">
          View Incident Details
        </a>
      </p>
    </div>
  </div>

  <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">
  <p style="color: #999; font-size: 12px;">
    This is an automated SLA notification from ServiceNow ITSM Demo.
  </p>
</body>
</html>
    </message_html>
    <weight>100</weight>
  </sysevent_email_action>
</unload>
